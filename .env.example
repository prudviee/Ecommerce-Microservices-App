# Docker service names as hostnames (used inside docker-compose)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=ecom_user
MYSQL_PASSWORD=ecom_pass
MYSQL_DATABASE=ecommerce
ES_HOST=http://elasticsearch:9200
APP_PORT=8000

# For local development without Docker, change to:
# MYSQL_HOST=localhost
# ES_HOST=http://localhost:9200
